</head>
<body class="p-4 md:p-6 text-gray-200 custom-scroll">

  <div class="max-w-7xl mx-auto">
    <!-- Header + Language Switcher -->
    <div class="flex flex-wrap justify-between items-center mb-6 gap-3">
