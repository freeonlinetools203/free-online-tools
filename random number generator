<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Random Number Generator - Free Online Tools</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #1E3A8A 0%, #0D9488 100%);
            min-height: 100vh;
            padding: 16px;
            transition: all 0.3s ease;
        }

        body.dark-mode {
            background: linear-gradient(135deg, #0f172a 0%, #0f766e 100%);
        }

        .container {
            max-width: 100%;
            margin: 0 auto;
        }

        .card {
            background: white;
            border-radius: 32px;
            padding: 24px 20px 32px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.25);
            transition: all 0.3s ease;
            text-align: center;
        }

        body.dark-mode .card {
            background: #1e293b;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }

        h1 {
            color: #1E3A8A;
            font-size: 24px;
        }

        body.dark-mode h1 {
            color: #0D9488;
        }

        .sub {
            color: #0D9488;
            font-size: 12px;
            font-weight: 500;
        }

        body.dark-mode .sub {
            color: #5eead4;
        }

        .dark-toggle {
            background: #f1f5f9;
            border: none;
            padding: 10px 16px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }

        body.dark-mode .dark-toggle {
            background: #334155;
            color: white;
        }

        .range-section {
            background: #f8fafc;
            border-radius: 24px;
            padding: 20px;
            margin-bottom: 24px;
        }

        body.dark-mode .range-section {
            background: #334155;
        }

        .range-row {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-bottom: 15px;
        }

        .range-box {
            flex: 1;
        }

        .range-label {
            font-weight: 700;
            color: #1E3A8A;
            margin-bottom: 8px;
            font-size: 13px;
            display: block;
        }

        body.dark-mode .range-label {
            color: #5eead4;
        }

        .range-input {
            width: 100%;
            padding: 14px;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            font-size: 16px;
            text-align: center;
            background: white;
        }

        body.dark-mode .range-input {
            background: #1e293b;
            color: white;
            border-color: #0D9488;
        }

        .count-section {
            margin-top: 15px;
        }

        .result-card {
            background: linear-gradient(135deg, #1E3A8A 0%, #0D9488 100%);
            border-radius: 24px;
            padding: 35px;
            text-align: center;
            margin: 20px 0;
        }

        .result-number {
            font-size: 64px;
            font-weight: bold;
            color: white;
            word-break: break-word;
        }

        .generate-btn {
            background: linear-gradient(135deg, #1E3A8A 0%, #0D9488 100%);
            color: white;
            border: none;
            padding: 16px 32px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 60px;
            cursor: pointer;
            margin: 10px 0;
            width: 100%;
        }

        .multiple-results {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin: 20px 0;
        }

        .multiple-number {
            background: #f1f5f9;
            padding: 12px 18px;
            border-radius: 16px;
            font-size: 18px;
            font-weight: bold;
            color: #1E3A8A;
        }

        body.dark-mode .multiple-number {
            background: #334155;
            color: #5eead4;
        }

        .action-buttons {
            display: flex;
            gap: 12px;
            margin-top: 15px;
        }

        .action-btn {
            flex: 1;
            background: #0D9488;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
        }

        .info-text {
            text-align: center;
            color: #0D9488;
            font-size: 12px;
            background: #f0fdf4;
            padding: 12px;
            border-radius: 16px;
            margin-top: 20px;
        }

        body.dark-mode .info-text {
            background: #0f766e;
            color: #ccfbf1;
        }

        @media (min-width: 600px) {
            body { padding: 30px; }
            .container { max-width: 550px; margin: 0 auto; }
            .result-number { font-size: 80px; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <div class="header">
                <div>
                    <h1>🔢 Random Number Generator</h1>
                    <p class="sub">Generate random numbers</p>
                </div>
                <button class="dark-toggle" onclick="toggleDarkMode()">🌙 Dark Mode</button>
            </div>

            <div class="range-section">
                <div class="range-row">
                    <div class="range-box">
                        <label class="range-label">📉 Min</label>
                        <input type="number" id="minValue" class="range-input" value="1">
                    </div>
                    <div class="range-box">
                        <label class="range-label">📈 Max</label>
                        <input type="number" id="maxValue" class="range-input" value="100">
                    </div>
                </div>
                <div class="count-section">
                    <label class="range-label">🔢 How many numbers?</label>
                    <input type="number" id="countValue" class="range-input" value="1" min="1" max="20">
                </div>
            </div>

            <div class="result-card">
                <div class="result-number" id="result">—</div>
            </div>

            <div id="multipleResults" class="multiple-results"></div>

            <button class="generate-btn" onclick="generateNumbers()">🎲 GENERATE</button>

            <div class="action-buttons">
                <button class="action-btn" onclick="copyResult()">📋 Copy Result</button>
                <button class="action-btn" onclick="clearResult()">🗑️ Clear</button>
            </div>

            <div class="info-text">
                💡 Set min, max and count • Generate random numbers for lottery, games, or anything!
            </div>
        </div>
    </div>

    <script>
        let currentResult = '';

        function generateNumbers() {
            let min = parseInt(document.getElementById('minValue').value);
            let max = parseInt(document.getElementById('maxValue').value);
            let count = parseInt(document.getElementById('countValue').value);
            
            if (isNaN(min)) min = 1;
            if (isNaN(max)) max = 100;
            if (isNaN(count)) count = 1;
            
            if (min > max) {
                let temp = min;
                min = max;
                max = temp;
                document.getElementById('minValue').value = min;
                document.getElementById('maxValue').value = max;
            }
            
            if (count < 1) count = 1;
            if (count > 20) count = 20;
            
            let numbers = [];
            for (let i = 0; i < count; i++) {
                let num = Math.floor(Math.random() * (max - min + 1)) + min;
                numbers.push(num);
            }
            
            if (count === 1) {
                currentResult = numbers[0].toString();
                document.getElementById('result').innerHTML = numbers[0];
                document.getElementById('multipleResults').innerHTML = '';
            } else {
                currentResult = numbers.join(', ');
                document.getElementById('result').innerHTML = 'Multiple Numbers';
                let container = document.getElementById('multipleResults');
                container.innerHTML = '';
                numbers.forEach(num => {
                    let div = document.createElement('div');
                    div.className = 'multiple-number';
                    div.innerHTML = num;
                    container.appendChild(div);
                });
            }
            
            if (navigator.vibrate) navigator.vibrate(50);
            showFeedback(`${count} number(s) generated!`, '#22c55e');
        }

        function copyResult() {
            if (currentResult === '') {
                showFeedback('Generate numbers first!', '#dc2626');
                return;
            }
            navigator.clipboard.writeText(currentResult);
            showFeedback('✅ Copied: ' + currentResult, '#0D9488');
        }

        function clearResult() {
            currentResult = '';
            document.getElementById('result').innerHTML = '—';
            document.getElementById('multipleResults').innerHTML = '';
            showFeedback('Cleared!', '#0D9488');
        }

        function showFeedback(msg, bgColor) {
            let feedback = document.createElement('div');
            feedback.innerText = msg;
            feedback.style.position = 'fixed';
            feedback.style.bottom = '30px';
            feedback.style.left = '50%';
            feedback.style.transform = 'translateX(-50%)';
            feedback.style.backgroundColor = bgColor;
            feedback.style.color = 'white';
            feedback.style.padding = '12px 24px';
            feedback.style.borderRadius = '50px';
            feedback.style.fontSize = '14px';
            feedback.style.zIndex = '1000';
            document.body.appendChild(feedback);
            setTimeout(() => { feedback.remove(); }, 2000);
        }

        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            let btn = document.querySelector('.dark-toggle');
            if (document.body.classList.contains('dark-mode')) {
                btn.innerHTML = '☀️ Light Mode';
                localStorage.setItem('darkMode', 'enabled');
            } else {
                btn.innerHTML = '🌙 Dark Mode';
                localStorage.setItem('darkMode', 'disabled');
            }
        }

        function loadDarkMode() {
            let darkMode = localStorage.getItem('darkMode');
            if (darkMode === 'enabled') {
                document.body.classList.add('dark-mode');
                document.querySelector('.dark-toggle').innerHTML = '☀️ Light Mode';
            }
        }

        window.onload = loadDarkMode();
    </script>
</body>
</html>
